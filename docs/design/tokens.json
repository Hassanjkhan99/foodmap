{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "FoodMap design tokens — chosen visual direction 'Liquid Glass' (warm-tinted). Translucent, layered chrome with an ADAPTIVE-CONTRAST fallback to solid surfaces in moving_compact, bright ambient light, and reduced-transparency. Sunlight-legible, calm, food-forward, map-compatible. Light + dark. Consumable by Tailwind.",
  "meta": {
    "version": "0.2.0",
    "direction": "liquid-glass",
    "notes": "Liquid Glass is the signature aesthetic for CHROME and OVERLAYS (sheets, banners, control bars, chips) — not for primary reading content. Platform chrome stays neutral-tinted; restaurant imagery/merchant branding provides content-level color. Status is never communicated by color alone (pair with icon/label). Glass MUST degrade to the matching solid surface token when adaptiveContrast triggers fire (see glass.adaptiveContrast)."
  },
  "color": {
    "light": {
      "bg": { "$value": "#FBFAF7", "$type": "color" },
      "surface": { "$value": "#FFFFFF", "$type": "color" },
      "surfaceRaised": { "$value": "#FFFFFF", "$type": "color" },
      "surfaceSunken": { "$value": "#F2F0EA", "$type": "color" },
      "textPrimary": { "$value": "#1A1A17", "$type": "color" },
      "textSecondary": { "$value": "#5B5850", "$type": "color" },
      "textInverse": { "$value": "#FFFFFF", "$type": "color" },
      "border": { "$value": "#E4E0D7", "$type": "color" },
      "brand": { "$value": "#E8580C", "$type": "color", "$description": "Warm ember accent; used sparingly for primary action + selected marker." },
      "brandPressed": { "$value": "#C6480A", "$type": "color" },
      "onBrand": { "$value": "#FFFFFF", "$type": "color" },
      "focusRing": { "$value": "#1F6FEB", "$type": "color" },
      "status": {
        "open": { "$value": "#1E7A46", "$type": "color" },
        "closed": { "$value": "#8A8A8A", "$type": "color" },
        "unknown": { "$value": "#6B6B6B", "$type": "color" },
        "warning": { "$value": "#B26A00", "$type": "color" },
        "error": { "$value": "#C0392B", "$type": "color" },
        "info": { "$value": "#1F6FEB", "$type": "color" }
      },
      "map": {
        "markerSelected": { "$value": "#E8580C", "$type": "color" },
        "markerUnselected": { "$value": "#3A3A3A", "$type": "color" },
        "markerBehind": { "$value": "#B8B4AB", "$type": "color" },
        "currentLocation": { "$value": "#1F6FEB", "$type": "color" },
        "routePolyline": { "$value": "#2A6DF4", "$type": "color" },
        "routePolylineTravelled": { "$value": "#C4C0B7", "$type": "color" }
      }
    },
    "dark": {
      "bg": { "$value": "#14130F", "$type": "color" },
      "surface": { "$value": "#1E1C17", "$type": "color" },
      "surfaceRaised": { "$value": "#26241E", "$type": "color" },
      "surfaceSunken": { "$value": "#0F0E0B", "$type": "color" },
      "textPrimary": { "$value": "#F5F2EA", "$type": "color" },
      "textSecondary": { "$value": "#B4AFA3", "$type": "color" },
      "textInverse": { "$value": "#14130F", "$type": "color" },
      "border": { "$value": "#38352D", "$type": "color" },
      "brand": { "$value": "#FF7A33", "$type": "color" },
      "brandPressed": { "$value": "#E8580C", "$type": "color" },
      "onBrand": { "$value": "#1A1206", "$type": "color" },
      "focusRing": { "$value": "#5B9BFF", "$type": "color" },
      "status": {
        "open": { "$value": "#4FBE7E", "$type": "color" },
        "closed": { "$value": "#9A968C", "$type": "color" },
        "unknown": { "$value": "#A5A199", "$type": "color" },
        "warning": { "$value": "#E0A44B", "$type": "color" },
        "error": { "$value": "#F0776A", "$type": "color" },
        "info": { "$value": "#5B9BFF", "$type": "color" }
      },
      "map": {
        "markerSelected": { "$value": "#FF7A33", "$type": "color" },
        "markerUnselected": { "$value": "#D8D4C9", "$type": "color" },
        "markerBehind": { "$value": "#6E6A61", "$type": "color" },
        "currentLocation": { "$value": "#5B9BFF", "$type": "color" },
        "routePolyline": { "$value": "#5B9BFF", "$type": "color" },
        "routePolylineTravelled": { "$value": "#4A473F", "$type": "color" }
      }
    }
  },
  "glass": {
    "$description": "Liquid Glass surface recipe. Apply to chrome/overlays only. Each layer = tint fill over a backdrop blur, plus a 1px top highlight and hairline border for the 'lensed' edge. When adaptiveContrast triggers, drop backdrop-filter and use the solid `fallbackSurface` at full opacity.",
    "light": {
      "tintThin": { "$value": "rgba(255,255,255,0.55)", "$type": "color", "$description": "Light overlays (chips, control bars)." },
      "tintRegular": { "$value": "rgba(251,250,247,0.68)", "$type": "color", "$description": "Sheets, banners." },
      "tintThick": { "$value": "rgba(251,250,247,0.82)", "$type": "color", "$description": "Dense content over busy map." },
      "highlight": { "$value": "rgba(255,255,255,0.75)", "$type": "color", "$description": "1px inner top edge highlight." },
      "border": { "$value": "rgba(20,19,15,0.10)", "$type": "color", "$description": "Hairline lens edge." },
      "shadow": { "$value": "rgba(20,19,15,0.18)", "$type": "color" },
      "fallbackSurface": { "$value": "#FFFFFF", "$type": "color", "$description": "Solid replacement when glass is disabled." },
      "scrim": { "$value": "rgba(20,19,15,0.28)", "$type": "color", "$description": "Behind modal sheets to lift contrast." }
    },
    "dark": {
      "tintThin": { "$value": "rgba(38,36,30,0.48)", "$type": "color" },
      "tintRegular": { "$value": "rgba(30,28,23,0.62)", "$type": "color" },
      "tintThick": { "$value": "rgba(20,19,15,0.80)", "$type": "color" },
      "highlight": { "$value": "rgba(255,255,255,0.12)", "$type": "color" },
      "border": { "$value": "rgba(255,255,255,0.10)", "$type": "color" },
      "shadow": { "$value": "rgba(0,0,0,0.45)", "$type": "color" },
      "fallbackSurface": { "$value": "#1E1C17", "$type": "color" },
      "scrim": { "$value": "rgba(0,0,0,0.45)", "$type": "color" }
    },
    "blur": {
      "thin": { "$value": "12px", "$type": "dimension", "$description": "backdrop-filter blur radius." },
      "regular": { "$value": "20px", "$type": "dimension" },
      "thick": { "$value": "32px", "$type": "dimension" },
      "saturate": { "$value": "150%", "$type": "other", "$description": "Optional backdrop saturation for the 'liquid' vibrancy." }
    },
    "radius": { "$value": "22px", "$type": "dimension", "$description": "Continuous-corner radius for glass panels." },
    "minContentContrast": { "$value": "4.5:1", "$type": "other", "$description": "Text on any glass layer must still meet WCAG AA; if a busy backdrop threatens this, escalate tint (thin->regular->thick) or fall back to solid." },
    "adaptiveContrast": {
      "$value": "solid-fallback",
      "$type": "other",
      "$description": "Disable backdrop-filter and use fallbackSurface at full opacity when ANY of: presentationContext == moving_compact | unknown_compact; prefers-reduced-transparency: reduce; prefers-contrast: more; forced-colors: active; measured/ambient-light high (sunlight) where available; or the GPU/browser lacks backdrop-filter support. Primary reading content (Ahead rows, venue names, time/distance) is NEVER placed directly on a translucent layer without a solid content plate."
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif", "$type": "fontFamily" },
      "numeric": { "$value": "\"Inter\", system-ui, sans-serif", "$type": "fontFamily", "$description": "Tabular numerals for time/distance/detour." }
    },
    "scale": {
      "display": { "$value": { "fontSize": "28px", "lineHeight": "34px", "fontWeight": 700 }, "$type": "typography" },
      "title": { "$value": { "fontSize": "22px", "lineHeight": "28px", "fontWeight": 700 }, "$type": "typography" },
      "cardTitle": { "$value": { "fontSize": "18px", "lineHeight": "24px", "fontWeight": 600 }, "$type": "typography" },
      "body": { "$value": { "fontSize": "16px", "lineHeight": "24px", "fontWeight": 400 }, "$type": "typography" },
      "bodyStrong": { "$value": { "fontSize": "16px", "lineHeight": "24px", "fontWeight": 600 }, "$type": "typography" },
      "meta": { "$value": { "fontSize": "14px", "lineHeight": "20px", "fontWeight": 500 }, "$type": "typography" },
      "movingPrimary": { "$value": { "fontSize": "20px", "lineHeight": "26px", "fontWeight": 700 }, "$type": "typography", "$description": "Minimum comfortable size for moving_compact primary text." }
    }
  },
  "space": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "elevation": {
    "0": { "$value": "none", "$type": "shadow" },
    "1": { "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(20,19,15,0.08)" }, "$type": "shadow" },
    "2": { "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "-2px", "color": "rgba(20,19,15,0.12)" }, "$type": "shadow" },
    "sheet": { "$value": { "offsetX": "0px", "offsetY": "-6px", "blur": "24px", "spread": "0px", "color": "rgba(20,19,15,0.16)" }, "$type": "shadow" }
  },
  "touchTarget": {
    "min": { "$value": "44px", "$type": "dimension", "$description": "Minimum in stationary. " },
    "movingMin": { "$value": "56px", "$type": "dimension", "$description": "Minimum in moving_compact for large one-handed targets." }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "120ms", "$type": "duration" },
      "base": { "$value": "200ms", "$type": "duration" },
      "sheet": { "$value": "260ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" }
    },
    "reducedMotion": {
      "$value": "disable-nonessential",
      "$type": "other",
      "$description": "prefers-reduced-motion: no camera animation, no row reshuffle animation, instant value updates."
    },
    "movingRules": {
      "$value": "no-constant-animation",
      "$type": "other",
      "$description": "In moving_compact: no constant camera animation, no row reshuffle, values update in place."
    }
  },
  "zIndex": {
    "map": { "$value": 0, "$type": "number" },
    "overlayControls": { "$value": 10, "$type": "number" },
    "banner": { "$value": 20, "$type": "number" },
    "sheet": { "$value": 30, "$type": "number" },
    "toast": { "$value": 40, "$type": "number" }
  }
}
